Sending keys: ['cat > test_api.py << \'EOF\'\nimport requests\nimport json\n\nbase_url = "http://localhost:5000"\n\n# Test 1: Create first task\nprint("Creating first task...")\nresponse = requests.post(f"{base_url}/tasks", json={"title": "First Task"})\nprint(f"Status: {response.status_code}")\nprint(f"Response: {response.json()}")\ntask1_id = response.json()["id"]\n\n# Test 2: Create second task to verify unique IDs\nprint("\\nCreating second task...")\nresponse = requests.post(f"{base_url}/tasks", json={"title": "Second Task"})\nprint(f"Status: {response.status_code}")\nprint(f"Response: {response.json()}")\ntask2_id = response.json()["id"]\n\nprint(f"\\nTask IDs: {task1_id}, {task2_id}")\nprint(f"IDs are unique: {task1_id != task2_id}")\n\n# Test 3: List all tasks\nprint("\\nListing all tasks...")\nresponse = requests.get(f"{base_url}/tasks")\nprint(f"Status: {response.status_code}")\nprint(f"Tasks: {response.json()}")\n\n# Test 4: Test complete endpoint with non-existent task\nprint("\\nTesting complete endpoint with non-existent task...")\nresponse = requests.put(f"{base_url}/tasks/999/complete")\nprint(f"Status: {response.status_code}")\nprint(f"Response: {response.json()}")\nprint(f"Correct status code (404): {response.status_code == 404}")\n\n# Test 5: Complete existing task\nprint("\\nCompleting first task...")\nresponse = requests.put(f"{base_url}/tasks/{task1_id}/complete")\nprint(f"Status: {response.status_code}")\nprint(f"Response: {response.json()}")\n\n# Test 6: Delete task\nprint("\\nDeleting second task...")\nresponse = requests.delete(f"{base_url}/tasks/{task2_id}")\nprint(f"Status: {response.status_code}")\nprint(f"Response: {response.json()}")\n\n# Test 7: List tasks after deletion\nprint("\\nListing tasks after deletion...")\nresponse = requests.get(f"{base_url}/tasks")\nprint(f"Status: {response.status_code}")\nprint(f"Tasks: {response.json()}")\nprint(f"Number of tasks after deletion: {len(response.json())}")\nEOF\n'] min_timeout_sec: 0.1 max