[18.170552, "o", "sed -i 's/tasks = \\[t for t in tasks if t\\[\"id\"\\] == task_id\\]/tasks = [t for t in tasks if t[\"id\"] != task_id]/' /app/app.py\r\n\u001b[?2004l\r"]
